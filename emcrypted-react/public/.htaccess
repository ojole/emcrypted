Options -MultiViews
RewriteEngine On
RewriteBase /

# Let existing files/directories pass through unchanged.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route all SPA paths through index.html.
RewriteRule ^ index.html [L]

# If the host emits auth/not-found for deep links, recover to SPA shell.
ErrorDocument 401 /index.html
ErrorDocument 404 /index.html
